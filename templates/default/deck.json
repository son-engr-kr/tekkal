        },
        {
          "id": "tikz-flow",
          "type": "tikz",
          "content": "\\begin{tikzpicture}[node distance=1.5cm, auto,\n    block/.style={rectangle, draw, fill=blue!20, text width=4em, text centered, rounded corners, minimum height=2.5em},\n    line/.style={draw, -latex}]\n  \\node [block] (input) {Input};\n  \\node [block, right of=input, node distance=3cm] (process) {Process};\n  \\node [block, right of=process, node distance=3cm] (output) {Output};\n  \\path [line] (input) -- (process);\n  \\path [line] (process) -- (output);\n\\end{tikzpicture}",
          "position": { "x": 640, "y": 90 },
          "size": { "w": 290, "h": 190 },
          "svgUrl": "./assets/tikz/tikz-flow.svg"
        },
        {
          "id": "tikzd-nn",
          "type": "tikz",
          "content": "\\begin{tikzpicture}[x=1.8cm, y=1.2cm,\n    node/.style={circle, draw, minimum size=6mm, inner sep=0pt, fill=blue!15},\n    >=latex]\n  \\foreach \\i in {1,...,3}\n    \\node[node] (I-\\i) at (0,-\\i) {};\n  \\foreach \\j in {1,...,4}\n    \\node[node, fill=orange!20] (H-\\j) at (1.5,-\\j+0.5) {};\n  \\foreach \\k in {1,...,2}\n    \\node[node, fill=green!20] (O-\\k) at (3,-\\k-0.5) {};\n  \\foreach \\i in {1,...,3}\n    \\foreach \\j in {1,...,4}\n      \\draw[->] (I-\\i) -- (H-\\j);\n  \\foreach \\j in {1,...,4}\n    \\foreach \\k in {1,...,2}\n      \\draw[->] (H-\\j) -- (O-\\k);\n  \\node[above] at (0,-0.5) {\\small Input};\n  \\node[above] at (1.5,0) {\\small Hidden};\n  \\node[above] at (3,-0.5) {\\small Output};\n\\end{tikzpicture}",
