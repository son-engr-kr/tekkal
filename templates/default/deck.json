          "content": "\\begin{tikzpicture}\n  \\begin{axis}[\n    width=6cm, height=5cm,\n    xlabel=$x$, ylabel=$f(x)$,\n    grid=major,\n    title={$\\sin(x)$ and $\\cos(x)$}\n  ]\n    \\addplot[green, thick, domain=0:360, samples=100] {sin(x)};\n    \\addplot[red, thick, dashed, domain=0:360, samples=100] {cos(x)};\n    \\legend{$\\sin$, $\\cos$}\n  \\end{axis}\n\\end{tikzpicture}",
          "position": { "x": 330, "y": 90 },
